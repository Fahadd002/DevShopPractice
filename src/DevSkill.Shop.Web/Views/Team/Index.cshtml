@using DevSkill.Shop.Domain.Entities

@model List<Team>

@{
    ViewData["Title"] = "Our Team";
}

<div class="container mt-5">
    <h2 class="text-center mb-5 fw-bold">Meet Our Team</h2>

    <div class="row">
        @foreach (var member in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card shadow-sm border-0 h-100 text-center">

                    <div class="p-3">
                        <img src="@Url.Content(member.ImageUrl)"
                             class="rounded-circle img-fluid"
                             style="width:120px; height:120px; object-fit:cover;"
                             alt="@member.Name">
                    </div>

                    <div class="card-body">
                        <h5 class="card-title fw-semibold">@member.Name</h5>
                        <p class="text-muted mb-1">@member.Designation</p>

                        <small class="text-secondary d-block">@member.Email</small>
                        <small class="text-secondary d-block">@member.Phone</small>

                        <span class="badge bg-@(member.Gender == Gender.Male ? "primary" : "danger") mt-2">
                            @member.Gender
                        </span>
                    </div>

                    <div class="card-footer bg-white border-0">
                        <small class="text-muted">
                            Joined: @member.JoiningDate.ToString("MMM yyyy")
                        </small>
                    </div>

                </div>
            </div>
        }
    </div>
</div>